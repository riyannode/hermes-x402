# ── Seller Config ─────────────────────────────────────────────────────────────
X402_SELLER_ADDRESS=0xYOUR_WALLET_ADDRESS
X402_CHAIN=arcTestnet
# X402_FACILITATOR_URL=https://gateway-api-testnet.circle.com

# ── Buyer Config (DCW) ───────────────────────────────────────────────────────
CIRCLE_DCW_WALLET_ID=your-wallet-id
CIRCLE_DCW_WALLET_ADDRESS=0xYourWalletAddress
CIRCLE_ENTITY_SECRET=your-entity-secret
# CIRCLE_API_KEY=your-circle-api-key
# CIRCLE_DCW_BLOCKCHAIN=ARC-TESTNET

# ── Buyer Config (Circle CLI) ────────────────────────────────────────────────
# CIRCLE_AGENT_WALLET_ADDRESS=0xYourAgentWalletAddress
# CIRCLE_AGENT_WALLET_NETWORK=ARC-TESTNET
# CIRCLE_CLI_EXECUTABLE=circle
# CIRCLE_CLI_CWD=

# ── Network Policy ───────────────────────────────────────────────────────────
# X402_NETWORK_POLICY=public
#   Purpose: URL validation mode — "public" allows any public HTTPS host,
#   "strict_allowlist" only allows hosts in X402_HOST_ALLOWLIST.
#   Default: public. Valid values: public, strict_allowlist.
#   Secret: no. Restart required: no.

# X402_HOST_ALLOWLIST=
#   Purpose: Comma-separated allowed hostnames. Only effective in
#   strict_allowlist mode. Empty means nothing is allowed in strict mode.
#   Default: "" (empty). Valid values: comma-separated hostnames.
#   Secret: no. Restart required: no.

# X402_ALLOW_HTTP=false
#   Purpose: Allow HTTP (non-HTTPS) URLs. Dev mode only.
#   Default: false. Valid values: true, false, 1, 0, yes, no.
#   Secret: no. Restart required: no.

# ── Discovery & Multi-Network ────────────────────────────────────────────────
# X402_DISCOVERY_PROVIDERS=circle_marketplace
#   Purpose: Comma-separated discovery providers for service search.
#   Default: circle_marketplace. Secret: no. Restart required: no.

# X402_NETWORK_PREFERENCE=base
#   Purpose: Comma-separated preferred network order for payment selection.
#   Default: base. Secret: no. Restart required: no.

# ── Buyer Safeguards ─────────────────────────────────────────────────────────
# X402_REQUIRE_GATEWAY_BATCHING=true
#   Purpose: Require Circle Gateway batching scheme.
#   Default: true. Secret: no. Restart required: no.

# X402_REQUIRE_APPROVAL_FOR_NEW_HOST=false
#   Purpose: Require user approval before paying a new host.
#   Default: false. Secret: no. Restart required: no.

# X402_MAX_USDC_PER_PAYMENT=0.01
#   Purpose: Maximum USDC per single payment. Required for CLI backend.
#   Default: none. Secret: no. Restart required: no.

# X402_DAILY_BUDGET_USDC=1.00
#   Purpose: Daily USDC spending cap (accepted but not enforced in this release).
#   Default: none. Secret: no. Restart required: no.
